  "keyFeatures": [
    "Generate music from text prompts via REST API",
    "Custom Mode: full control over lyrics, style tags, title, and negative tags",
    "Automatic hCaptcha solving via 2Captcha and Playwright",
    "OpenAI-compatible /v1/chat/completions endpoint",
    "Extend existing audio clips",
    "Separate audio into stems (vocal and instrumental tracks)",
    "Get word-level lyric alignment timestamps",
    "One-click deploy to Vercel or Docker",
    "Auto keep-alive to maintain active Suno session",
    "Support for multiple Suno accounts via Cookie header override"
  ],
  "publicApiSurface": [
    "POST /api/generate",
